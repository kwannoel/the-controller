# Optional: Override binary paths (defaults to PATH lookup)
# THE_CONTROLLER_GH_BIN=/usr/local/bin/gh
# THE_CONTROLLER_GIT_BIN=/usr/local/bin/git
# THE_CONTROLLER_CODEX_BIN=/usr/local/bin/codex

# Optional: Dev server port (default: 1420)
# DEV_PORT=1420

# Project-level secrets are managed via: controller-cli env set KEY VALUE
# Deploy credentials (Hetzner/Cloudflare/Coolify) are configured through the app UI
